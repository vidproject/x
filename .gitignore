# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Node
node_modules/

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Local build outputs only (committed artifacts are NOT here)
extension/dist/
extension/.web-ext-artifacts/

# Local secrets — never commit
.env
.env.local
.envrc

# Coverage / temp
htmlcov/
coverage.xml
.coverage
tmp/

# Derived artifacts — deterministic from canonical data + tooling, not committed.
# Layer 2+ tag scripts (keyframe extraction, OCR, transcripts) write here on
# the CI runner; the metadata about each artifact lives in data/tags/*.parquet
# but the bytes themselves are regenerable.
data/derived/
