    {
      "tweet_id": "2054230225555165363",
      "account_handle": "Know2Protect",
      "account_id": "1720087919149686785",
      "posted_at": "2026-05-12T16:00:26.000Z",
      "first_captured_at": "2026-05-19T23:28:05.653Z",
      "last_seen_at": "2026-05-19T23:28:05.653Z",
      "deletion_detected_at": null,
      "tweet_url": "https://x.com/Know2Protect/status/2054230225555165363",
      "tweet_type": "original",
      "conversation_id": "2054230225555165363",
