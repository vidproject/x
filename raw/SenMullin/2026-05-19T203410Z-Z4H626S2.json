    {
      "tweet_id": "2029238001553805755",
      "account_handle": "SenMullin",
      "account_id": "1060370282",
      "posted_at": "2026-03-04T16:50:15.000Z",
      "first_captured_at": "2026-05-19T20:34:10.370Z",
